{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": [
    "nushell@0.113.1",
    "kubernetes-helm@4.2.3",
    "git@2.54.0",
    "yq-go@4.53.3",
    "vals@0.44.3",
    "kubectl-tree@0.6.0",
    "linode-cli@5.56.2",
    "path:gcloud#google-cloud-sdk",
    "viddy@1.3.1"
  ],
  "shell": {
    "init_hook": [
      "export PATH=\"$HOME/.local/bin:$HOME/.npm-global/bin:$PATH\"",
      "if [ -n \"$USE_VALS\" ]; then eval \"$(vals env -export -f .env.vals.yaml)\"; fi",
      "if [ -f .env ]; then source .env; fi"
    ],
    "scripts": {
      "agent": ["claude"]
    }
  }
}
